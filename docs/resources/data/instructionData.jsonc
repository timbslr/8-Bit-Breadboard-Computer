    {
      "name": "move",
      "mnemonic": "mov",
      "type": "REAL",
      "operands": ["regd", "regs"],
      "requiresFlag": false,
      "opcode": "FILE", // all opcodes for the move-combinations are loaded from the movData file
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_<regs>", "IE_<regd>"], //move from source to destination register
        ["RSC"]
      ],
      "group": "REG-MEM",
      "shortDescription": "<regd> = <regs>"
    },
    {
      "name": "load",
      "mnemonic": "ld",
      "type": "REAL",
      "operands": ["reg", "addr"],
      "requiresFlag": false,
      "opcode": "00010RRR",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //           ──┐
        ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch first operand (= low byte of address) and move it into the buffer
        ["MEM_EN_IO", "IE_BUF", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //             ──┐
        ["OE_PC_L", "IE_MAR_L"], //               ├──> Fetch second operand (= high byte of address) and move it into MAR_H
        ["MEM_EN_IO", "IE_MAR_H", "INC_PC"], // ──┘
        ["OE_BUF", "IE_MAR_L"], //move buffer value (= low byte of address) to MAR_L
        ["MEM_EN_IO", "IE_<reg>"], //read from memory at fetched address and move the result to the given register
        ["RSC"]
      ],
      "group": "REG-MEM",
      "shortDescription": "<reg> = mem[<addr>]"
    },
    {
      "name": "load with offset",
      "mnemonic": "ldo",
      "type": "REAL",
      "operands": ["reg", "idxreg", "addr"],
      "requiresFlag": true,
      "opcode": "0011RRRX",
      "microinstructions": {
        "0": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_<idxreg>", "IE_TMP"], //move X-Register to TMP-Register
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (stored in the X-Register) and move result into Buffer-Register
          ["OE_PC_H", "IE_MAR_H"], //             ──┐
          ["OE_PC_L", "IE_MAR_L"], //               ├──> Fetch second operand (= high byte of address) and move it into MAR_H (--> No Carry occurred, so we can directly move the high byte of the address into MAR_H)
          ["MEM_EN_IO", "IE_MAR_H", "INC_PC"], // ──┘
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "IE_<reg>"], //read from memory at computed address and move the result to the given register
          ["RSC"]
        ],
        "1": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_<idxreg>", "IE_TMP"], //move X-Register to TMP-Register
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (stored in the X-Register) and move result into Buffer-Register
          ["OE_PC_H", "IE_MAR_H"], //                    ──┐
          ["OE_PC_L", "IE_MAR_L"], //                      ├──> Fetch second operand (= high byte of address) and move it into the A-Register (--> Carry occurred, so we have to increment the high byte of the address)
          ["MEM_EN_IO", "IE_A", "INC_PC", "RST_TMP"], // ──┘ //set TMP-Register to 0 (needed in the next step in order to increment)
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_H"], //add one to the high byte of the address (because a carry occurred)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "IE_<reg>"], //read from memory at computed address and move the result to the given register
          ["RSC"]
        ]
      },
      "group": "REG-MEM",
      "shortDescription": "<reg> = mem[<addr> + <idxreg>]"
    },
    {
      "name": "load indirect register",
      "mnemonic": "ldindr",
      "type": "REAL",
      "operands": ["reg"],
      "requiresFlag": false,
      "opcode": "11010RRR",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_A", "IE_MAR_H"],
        ["OE_TMP", "IE_MAR_L"],
        ["MEM_EN_IO", "IE_<reg>"],
        ["RSC"]
      ],
      "group": "REG-MEM",
      "shortDescription": "<reg> = mem[A << 8 | TMP]"
    },
    {
      "name": "load stack-pointer relative",
      "mnemonic": "ldsprel",
      "type": "REAL",
      "operands": ["reg", "imm"],
      "requiresFlag": true,
      "opcode": "01010RRR",
      "microinstructions": {
        "0": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_SP_L", "IE_A"], //move SP_L to A-Register
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch operand (= immediate) and move it into the TMP-Register
          ["MEM_EN_IO", "IE_TMP", "INC_PC"], // ──┘
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset and move result into Buffer-Register
          ["OE_SP_H", "IE_MAR_H"], //  Move SP_H into MAR_H (--> No Carry occurred, so we can directly move the high byte of the address into MAR_H)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "IE_<reg>"], //read from memory at computed address and move the result to the given register
          ["RSC"]
        ],
        "1": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_SP_L", "IE_A"], //move SP_L to A-Register
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch operand (= immediate) and move it into the TMP-Register
          ["MEM_EN_IO", "IE_TMP", "INC_PC"], // ──┘
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset and move result into Buffer-Register
          ["OE_SP_H", "IE_A", "RST_TMP"], // Move SP_H into the A-Register (--> Carry occurred, so we have to increment the high byte of the address), set TMP to zero (needed in the next step in order to increment)
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_H"], //add one to the high byte of the address (because a carry occurred)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "IE_<reg>"], //read from memory at computed address and move the result to the given register
          ["RSC"]
        ]
      },
      "group": "REG-MEM",
      "shortDescription": "<reg> = mem[SP + <immediate>]"
    },
    {
      "name": "store",
      "mnemonic": "st",
      "type": "REAL",
      "operands": ["reg", "addr"],
      "requiresFlag": false,
      "opcode": "00011RRR",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //           ──┐
        ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch first operand (= low byte of address) and move it into the buffer
        ["MEM_EN_IO", "IE_BUF", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //             ──┐
        ["OE_PC_L", "IE_MAR_L"], //               ├──> Fetch second operand (= high byte of address) and move it into MAR_H
        ["MEM_EN_IO", "IE_MAR_H", "INC_PC"], // ──┘
        ["OE_BUF", "IE_MAR_L"], //move buffer value (= low byte of address) to MAR_L
        ["MEM_EN_IO", "MEM_WE", "OE_<reg>"], //store the value of the given register into memory at the fetched address
        ["RSC"]
      ],
      "group": "REG-MEM",
      "shortDescription": "mem[<addr>] = <reg>"
    },
    {
      "name": "store with offset",
      "mnemonic": "sto",
      "type": "REAL",
      "operands": ["reg", "idxreg", "addr"],
      "requiresFlag": true,
      "opcode": "0100RRRX",
      "microinstructions": {
        "0": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_<reg>", "IE_C"], //save the source-register in the C-Register, otherwise, this instructions wouldn't allow the A- and TMP-Register as source //TODO check what happens if source is C => OE_C, IE_C
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_<idxreg>", "IE_TMP"], //move X- or Y-Register to TMP-Register
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (stored in the X- or Y-Register) and move result into Buffer-Register
          ["OE_PC_H", "IE_MAR_H"], //             ──┐
          ["OE_PC_L", "IE_MAR_L"], //               ├──> Fetch second operand (= high byte of address) and move it into MAR_H (--> No Carry occurred, so we can directly move the high byte of the address into MAR_H)
          ["MEM_EN_IO", "IE_MAR_H", "INC_PC"], // ──┘
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "MEM_WE", "OE_C"], //store the value of the given register into memory at the computed address
          ["RSC"]
        ],
        "1": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_<reg>", "IE_C"], //save the source-register in the C-Register, otherwise, this instructions wouldn't allow the A- and TMP-Register as source //TODO check what happens if source is C => OE_C, IE_C
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_<idxreg>", "IE_TMP"], //move X- or Y-Register to TMP-Register
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (stored in the X- or Y-Register) and move result into Buffer-Register
          ["OE_PC_H", "IE_MAR_H"], //                    ──┐
          ["OE_PC_L", "IE_MAR_L"], //                      ├──> Fetch second operand (= high byte of address) and move it into the A-Register (--> Carry occurred, so we have to increment the high byte of the address)
          ["MEM_EN_IO", "IE_A", "INC_PC", "RST_TMP"], // ──┘ // set TMP to zero (needed in the next step in order to increment)
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_H"], //add one to the high byte of the address (because a carry occurred)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "MEM_WE", "OE_C"], //store the value of the given register into memory at the computed address
          ["RSC"]
        ]
      },
      "group": "REG-MEM",
      "shortDescription": "mem[<addr> + <idxreg>] = <reg>"
    },
    {
      "name": "store indirect register",
      "mnemonic": "stindr",
      "type": "REAL",
      "operands": ["reg"],
      "requiresFlag": false,
      "opcode": "11111RRR",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_A", "IE_MAR_H"],
        ["OE_TMP", "IE_MAR_L"],
        ["MEM_EN_IO", "MEM_WE", "OE_<reg>"],
        ["RSC"]
      ],
      "group": "REG-MEM",
      "shortDescription": "mem[A << 8 | TMP] = <reg>"
    },
    {
      "name": "store stack-pointer relative",
      "mnemonic": "stsprel",
      "type": "REAL",
      "operands": ["reg", "addr"],
      "requiresFlag": true,
      "opcode": "01011RRR",
      "microinstructions": {
        "0": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_<reg>", "IE_C"], //save the source-register in the C-Register, otherwise, this instructions wouldn't allow the A- and TMP-Register as source //TODO check what happens if source is C => OE_C, IE_C
          ["OE_SP_L", "IE_A"], //move SP_L to A-Register
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch operand (= immediate) and move it into the TMP-Register
          ["MEM_EN_IO", "IE_TMP", "INC_PC"], // ──┘
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (= immediate) and move result into Buffer-Register
          ["OE_SP_H", "IE_MAR_H"], // Move SP_H into MAR_H (--> No Carry occurred, so we can directly move the high byte of the address into MAR_H)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "MEM_WE", "OE_C"], //store the value of the given register into memory at the computed address
          ["RSC"]
        ],
        "1": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_<reg>", "IE_C"], //save the source-register in the C-Register, otherwise, this instructions wouldn't allow the A- and TMP-Register as source //TODO check what happens if source is C => OE_C, IE_C
          ["OE_SP_L", "IE_A"], //move SP_L to A-Register
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch operand (= immediate) and move it into the TMP-Register
          ["MEM_EN_IO", "IE_TMP", "INC_PC"], // ──┘
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "OE_ALU", "IE_BUF", "IE_F"], //add the low byte of the address to the offset (= immediate) and move result into Buffer-Register
          ["OE_SP_H", "IE_A", "RST_TMP"], // Move SP_H into the A-Register (--> Carry occurred, so we have to increment the high byte of the address), set TMP to zero (needed in the next step in order to increment)
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_H"], //add one to the high byte of the address (because a carry occurred)
          ["OE_BUF", "IE_MAR_L"], //computed address is now in MAR
          ["MEM_EN_IO", "MEM_WE", "OE_C"], //store the value of the given register into memory at the computed address
          ["RSC"]
        ]
      },
      "group": "REG-MEM",
      "shortDescription": "mem[SP + <imm>] = <reg>"
    },
    {
      "name": "load immediate",
      "mnemonic": "li",
