      "opcode": "00000101",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //           ──┐
        ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch first Operand (= low byte of the address to jump to) and move it into the buffer
        ["MEM_EN_IO", "IE_BUF", "INC_PC"], // ──┘
        ["OE_PC_H", "IE_MAR_H"], //           ──┐
        ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch second Operand (= high byte of the address to jump to) and move it into PC_H
        ["MEM_EN_IO", "IE_PC_H"], //          ──┘
        ["OE_BUF", "IE_PC_L"], //move buffer value (= low byte of address to jump to) to PC_L
        ["RSC"]
      ],
      "group": "BR-JMP",
      "shortDescription": "PC = <addr>"
    },
    {
      "name": "jump register",
      "mnemonic": "jmpr",
      "type": "REAL",
      "operands": [],
      "requiresFlag": false,
      "opcode": "00000110",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_A", "IE_PC_H"], //          ──┐
        ["OE_TMP", "IE_PC_L"], //        ──┴──> Set PC to values in A- and TMP-Register (high and low address byte)
        ["RSC"]
      ],
      "group": "BR-JMP",
      "shortDescription": "PC_H = A, PC_L = TMP"
    },
    {
      "name": "jump indirect",
      "mnemonic": "jmpind",
      "type": "REAL",
      "operands": ["addr"],
      "requiresFlag": true,
      "opcode": "00100110",
      "microinstructions": {
        "0": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch second operand (= high byte of address) and move it into the BUF-Register
          ["MEM_EN_IO", "IE_BUF", "INC_PC"], // ──┘
          ["OE_A", "IE_MAR_L"],
          ["OE_BUF", "IE_MAR_H"],
          ["MEM_EN_IO", "IE_PC_L", "RST_TMP"], //read from memory at read address and move the result into PC_L --> that's the final low byte of the address to be read, also resets TMP to zero for the next increment
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_L", "IE_F"], // increment addr_L and move the result into MAR_L
          ["OE_BUF", "IE_MAR_H"], // no carry occurred --> move BUF straight to MAR_H
          ["MEM_EN_IO", "IE_PC_H"] //access memory --> gives final high address byte
        ],
        "1": [
          ["OE_PC_H", "IE_MAR_H"], //          ──┐
          ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
          ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //         ──┐
          ["OE_PC_L", "IE_MAR_L"], //           ├──> Fetch first operand (= low byte of address) and move it into the A-Register
          ["MEM_EN_IO", "IE_A", "INC_PC"], // ──┘
          ["OE_PC_H", "IE_MAR_H"], //           ──┐
          ["OE_PC_L", "IE_MAR_L"], //             ├──> Fetch second operand (= high byte of address) and move it into the BUF-Register
          ["MEM_EN_IO", "IE_BUF", "INC_PC"], // ──┘
          ["OE_A", "IE_MAR_L"],
          ["OE_BUF", "IE_MAR_H"],
          ["MEM_EN_IO", "IE_PC_L", "RST_TMP"], //read from memory at read address and move the result into PC_L --> that's the final low byte of the address to be read, also resets TMP to zero for the next increment
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_L", "IE_F"], // increment addr_L and move the result into MAR_L
          ["OE_BUF", "IE_A"], // carry occurred --> move BUF into to A, TMP is still zero
          ["ALU_SRC_ARI", "ALU_AOP_ADD", "ALU_CIN", "OE_ALU", "IE_MAR_H"], // increment addr_H and move the result into MAR_H
          ["MEM_EN_IO", "IE_PC_H"] //access memory --> gives final high address byte]
        ]
      },
      "group": "BR-JMP",
      "shortDescription": "PC_L = mem[<addr>], PC_H = mem[<addr> + 1]"
    },
    {
