      "opcode": "10010RRR",
      "microinstructions": [
        ["OE_PC_H", "IE_MAR_H"], //          ──┐
        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["OE_SP_H", "IE_MAR_H"], // ──┬──> Move SP into MAR
        ["OE_SP_L", "IE_MAR_L"], // ──┘
        ["MEM_EN_IO", "MEM_WE", "OE_<reg>", "INC_SP"], //store value from given register into memory at address of SP, increment SP
        ["RSC"]
      ],
