        ["OE_PC_L", "IE_MAR_L"], //            ├──> Fetch Opcode
        ["MEM_EN_IO", "IE_IR", "INC_PC"], // ──┘
        ["DEC_SP"], // decrement SP to access the top element
        ["OE_SP_H", "IE_MAR_H"], // ──┬──> Move SP into MAR
        ["OE_SP_L", "IE_MAR_L"], // ──┘
        ["MEM_EN_IO", "IE_<reg>", "INC_SP"], //read from memory at current SP address and move the value into the specified register, increment SP again => only peek, not pop
        ["RSC"]
      ],
